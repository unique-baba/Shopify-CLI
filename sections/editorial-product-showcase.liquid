      color: {{ sec.button_text_color }};
    }
  {%- endif -%}
</style>

<script>
/**
 * Editorial Product Showcase — assets/editorial-product-showcase.js
 * Lightweight vanilla-JS scroll-in animation using IntersectionObserver.
 * No external libraries, no jQuery, no console errors.
 */
(function () {
  'use strict';

  function initEditorialShowcase(root) {
    if (!root || root.dataset.animation !== 'true') return;

    var targets = root.querySelectorAll('[data-aos]');
    if (!targets.length) return;

    if (!('IntersectionObserver' in window)) {
      // Fallback: reveal immediately if IntersectionObserver isn't supported.
      targets.forEach(function (el) {
        el.classList.add('is-visible');
      });
      return;
    }

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    targets.forEach(function (el, index) {
      // Slight stagger for a layered, editorial reveal.
      el.style.transitionDelay = (index * 90) + 'ms';
      observer.observe(el);
    });
  }

  function setupAll() {
    var sections = document.querySelectorAll('.editorial-showcase');
    sections.forEach(initEditorialShowcase);
  }

  document.addEventListener('DOMContentLoaded', setupAll);

  // Re-init when the section is added/edited live in the Theme Editor.
  document.addEventListener('shopify:section:load', function (event) {
    var section = event.target.querySelector('.editorial-showcase');
    if (section) initEditorialShowcase(section);
  });

  document.addEventListener('shopify:section:select', function (event) {
    var section = event.target.querySelector('.editorial-showcase');
    if (section) initEditorialShowcase(section);
  });
})();

</script>

