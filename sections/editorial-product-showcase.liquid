<style>
/* ============================================================================
   Editorial Product Showcase — assets/editorial-product-showcase.css
   Pixel-matched scrapbook / magazine collage layout.
   Layout model: a fixed-aspect-ratio canvas; every layer is positioned with
   percentage-based left/top/width so the whole composition scales fluidly
   and stays proportionally identical at every viewport — true to the
   reference design at any screen size, with no horizontal scroll.
   Mobile-first. No external libraries, no jQuery.
   ============================================================================ */

.editorial-showcase {
  position: relative;
  overflow: hidden;
  isolation: isolate;
}

.editorial-showcase__bg-image {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.editorial-showcase__bg-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

.editorial-showcase__container {
  position: relative;
  z-index: 1;
  width: 100%;
  margin: 0 auto;
  padding: 0 16px;
  box-sizing: border-box;
}

/* ----------------------------------------------------------------------
   The collage canvas — fixed aspect ratio, percentage-positioned children.
   This is what makes the layout pixel-proportional at every breakpoint.
   ---------------------------------------------------------------------- */

.editorial-showcase__canvas {
  position: relative;
  width: 100%;
  aspect-ratio: 1.15;
  overflow: hidden;
  box-shadow:
    0 2px 6px rgba(20, 16, 8, 0.06),
    0 18px 40px rgba(20, 16, 8, 0.10);
}

.editorial-showcase__canvas::before {
  /* subtle paper-grain texture overlay */
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
  background-image:
    repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.015) 0px,
      rgba(0, 0, 0, 0.015) 1px,
      transparent 1px,
      transparent 3px
    );
  mix-blend-mode: multiply;
}

/* All collage layers share absolute positioning set via inline style
   (left / top / width / height) generated from schema settings. */
.editorial-showcase__label-layer,
.editorial-showcase__heading-layer,
.editorial-showcase__badge-layer,
.editorial-showcase__body-layer,
.editorial-showcase__photo-layer,
.editorial-showcase__swatch-layer,
.editorial-showcase__tag-layer {
  position: absolute;
  z-index: 2;
}

/* ----------------------------------------------------------------------
   "NEW LAUNCH" hand-drawn label + scribble underline
   ---------------------------------------------------------------------- */

.editorial-showcase__label {
  display: block;
  font-family: "Segoe Print", "Bradley Hand", cursive, sans-serif;
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  color: #1a1a1a;
}

.editorial-showcase__label.is-handwritten {
  font-family: "Permanent Marker", "Segoe Print", "Bradley Hand", cursive, sans-serif;
}

.editorial-showcase__label.is-rotated {
  display: inline-block;
  transform: rotate(-2deg);
}

.editorial-showcase__scribble {
  display: block;
  width: 92%;
  height: 14px;
  margin-top: 2px;
  overflow: visible;
}

.editorial-showcase__scribble path {
  fill: none;
  stroke: #1a1a1a;
  stroke-width: 3.5;
  stroke-linecap: round;
}

/* ----------------------------------------------------------------------
   Heading
   ---------------------------------------------------------------------- */

.editorial-showcase__heading {
  margin: 0;
  font-weight: 800;
  line-height: 1.2;
  letter-spacing: -0.01em;
  text-transform: uppercase;
}

.editorial-showcase__heading * {
  margin: 0;
}

/* ----------------------------------------------------------------------
   Highlight badge
   ---------------------------------------------------------------------- */

.editorial-showcase__badge-layer {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 4px;
}

.editorial-showcase__highlight-tagline {
  display: inline-block;
  font-size: 0.72em;
  font-style: italic;
  font-weight: 500;
  padding-left: 4px;
}

.editorial-showcase__highlight-badge {
  display: inline-block;
  padding: 0.5em 1em;
  font-weight: 700;
  font-size: 1.05em;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  white-space: normal;
  line-height: 1.3;
}

.editorial-showcase__highlight-badge.is-rotated {
  transform: rotate(0.6deg);
}

.editorial-showcase__highlight-badge.has-shadow {
  box-shadow: 0 4px 10px rgba(20, 16, 8, 0.18);
}

/* ----------------------------------------------------------------------
   Description / body text
   ---------------------------------------------------------------------- */

.editorial-showcase__description {
  line-height: 1.5;
  font-weight: 400;
}

.editorial-showcase__description p {
  margin: 0 0 0.7em 0;
}

.editorial-showcase__description p:last-child {
  margin-bottom: 0;
}

.editorial-showcase__cta {
  margin-top: 1em;
}

.editorial-showcase__button {
  display: inline-block;
  padding: 0.7em 1.6em;
  font-size: 0.78em;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  text-decoration: none;
  transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease;
  cursor: pointer;
}

/* ----------------------------------------------------------------------
   Polaroid-style featured photo
   ---------------------------------------------------------------------- */

.editorial-showcase__photo-frame {
  position: relative;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 3.5% 3.5% 7% 3.5%;
  background-color: #faf6ef;
}

.editorial-showcase__photo-frame.is-rotated {
  transform: rotate(1.2deg);
}

.editorial-showcase__photo-frame.has-shadow {
  box-shadow:
    0 4px 10px rgba(20, 16, 8, 0.12),
    0 22px 46px rgba(20, 16, 8, 0.18);
}

.editorial-showcase__featured-img,
.editorial-showcase__placeholder {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ----------------------------------------------------------------------
   Fabric swatch card — zigzag / pinking-shears edge via clip-path
   ---------------------------------------------------------------------- */

.editorial-showcase__swatch-card {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  clip-path: polygon(
    0% 4%, 4% 0%, 8% 4%, 12% 0%, 16% 4%, 20% 0%, 24% 4%, 28% 0%,
    32% 4%, 36% 0%, 40% 4%, 44% 0%, 48% 4%, 52% 0%, 56% 4%, 60% 0%,
    64% 4%, 68% 0%, 72% 4%, 76% 0%, 80% 4%, 84% 0%, 88% 4%, 92% 0%,
    96% 4%, 100% 0%,
    100% 96%, 96% 100%, 92% 96%, 88% 100%, 84% 96%, 80% 100%, 76% 96%,
    72% 100%, 68% 96%, 64% 100%, 60% 96%, 56% 100%, 52% 96%, 48% 100%,
    44% 96%, 40% 100%, 36% 96%, 32% 100%, 28% 96%, 24% 100%, 20% 96%,
    16% 100%, 12% 96%, 8% 100%, 4% 96%, 0% 100%
  );
}

.editorial-showcase__swatch-card.is-rotated {
  transform: rotate(-5deg);
}

.editorial-showcase__swatch-card.has-shadow {
  box-shadow:
    0 3px 8px rgba(20, 16, 8, 0.14),
    0 16px 32px rgba(20, 16, 8, 0.18);
}

.editorial-showcase__swatch-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* folded-back corner suggesting the denim's contrast underside */
.editorial-showcase__swatch-fold {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 46%;
  height: 46%;
  background: linear-gradient(135deg, transparent 50%, rgba(120, 74, 40, 0.9) 50%);
  z-index: 2;
  pointer-events: none;
}

/* ----------------------------------------------------------------------
   Kraft string tag
   ---------------------------------------------------------------------- */

.editorial-showcase__tag-card {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 8% 10% 8% 16%;
  font-weight: 700;
  letter-spacing: 0.3px;
  text-transform: uppercase;
  line-height: 1.4;
}

.editorial-showcase__tag-card.is-rotated {
  transform: rotate(2deg);
}

.editorial-showcase__tag-card.has-shadow {
  box-shadow:
    0 3px 6px rgba(20, 16, 8, 0.12),
    0 12px 24px rgba(20, 16, 8, 0.16);
}

.editorial-showcase__tag-hole {
  position: absolute;
  left: 8%;
  top: 50%;
  width: 9%;
  aspect-ratio: 1 / 1;
  max-width: 16px;
  transform: translateY(-50%);
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.06);
  box-shadow:
    inset 0 1px 3px rgba(0, 0, 0, 0.3),
    0 0 0 2px rgba(120, 74, 24, 0.35);
}

.editorial-showcase__tag-text {
  font-size: clamp(11px, 2.6vw, 16px);
}

.editorial-showcase__tag-text p {
  margin: 0;
}

/* ----------------------------------------------------------------------
   Scroll-in animation (vanilla JS toggles .is-visible)
   ---------------------------------------------------------------------- */

[data-aos] {
  opacity: 0;
  will-change: opacity, transform;
  transition: opacity 0.7s ease, transform 0.7s ease;
}

[data-aos="fade-up"] {
  transform: translateY(24px);
}

[data-aos="fade-in"] {
  transform: translateY(0);
}

[data-aos="zoom-in"] {
  transform: scale(0.92);
}

[data-aos].is-visible {
  opacity: 1;
  transform: none;
}

@media (prefers-reduced-motion: reduce) {
  [data-aos] {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
}

/* ----------------------------------------------------------------------
   Font sizing scaffold — base em-relative sizing on the canvas itself so
   badge/description/tag text (sized in em) scale smoothly between the
   explicit mobile/desktop px breakpoints set inline by Liquid further
   below for label/heading/description.
   ---------------------------------------------------------------------- */

.editorial-showcase__badge-layer,
.editorial-showcase__tag-layer {
  font-size: clamp(11px, 2.4vw, 16px);
}

@media (min-width: 750px) {
  .editorial-showcase__container {
    padding: 0 32px;
  }
}

@media (min-width: 990px) {
  .editorial-showcase__container {
    padding: 0 40px;
  }

  .editorial-showcase__badge-layer,
  .editorial-showcase__tag-layer {
    font-size: clamp(13px, 1.3vw, 18px);
  }
}

/* ----------------------------------------------------------------------
   Mobile re-stack (below 700px) — the reference design's side-by-side
   percentage layout (text on the left half, photo on the right half)
   gets cramped on narrow phones. Below 700px we switch the canvas from
   a fixed-aspect absolute-position collage into a natural stacked flow:
   label → heading → badge → photo → swatch+tag → description. Percentage
   positions from Liquid are intentionally overridden here so the layout
   never collides or causes horizontal scroll on small screens.
   ---------------------------------------------------------------------- */

@media (max-width: 699px) {
  .editorial-showcase__canvas {
    aspect-ratio: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-areas:
      "label   label"
      "heading heading"
      "badge   badge"
      "photo   photo"
      "swatch  tag"
      "body    body";
    gap: 14px;
    padding: 20px 16px 28px;
    box-sizing: border-box;
  }

  .editorial-showcase__label-layer,
  .editorial-showcase__heading-layer,
  .editorial-showcase__badge-layer,
  .editorial-showcase__body-layer,
  .editorial-showcase__photo-layer,
  .editorial-showcase__swatch-layer,
  .editorial-showcase__tag-layer {
    position: static;
    left: auto !important;
    top: auto !important;
    width: 100% !important;
    height: auto !important;
  }

  .editorial-showcase__label-layer   { grid-area: label; }
  .editorial-showcase__heading-layer { grid-area: heading; }
  .editorial-showcase__badge-layer   { grid-area: badge; }
  .editorial-showcase__photo-layer   { grid-area: photo; }
  .editorial-showcase__swatch-layer  { grid-area: swatch; }
  .editorial-showcase__tag-layer     { grid-area: tag; }
  .editorial-showcase__body-layer    { grid-area: body; }

  .editorial-showcase__photo-layer .editorial-showcase__photo-frame {
    aspect-ratio: 4 / 5;
  }

  .editorial-showcase__swatch-card {
    aspect-ratio: 1 / 1;
  }

  .editorial-showcase__tag-card {
    aspect-ratio: 4 / 3;
  }

  .editorial-showcase__scribble {
    height: 10px;
  }
}

</style>
{%- if section.settings.use_handwritten_font -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap">
{%- endif -%}
{%- comment -%}
  ============================================================================
  Editorial Product Showcase Section — "Magazine Collage" layout
  ----------------------------------------------------------------------------
  Pixel-matched reproduction of a hand-drawn / scrapbook style product launch
  collage: torn-edge marker label, polaroid-style photo, rotated zigzag fabric
  swatch card, kraft string-tag, hand-drawn underline scribble.

  Layout model: a fixed-aspect-ratio "canvas" (like the original artboard)
  scaled fluidly with CSS, every layer positioned with percentage-based
  inset/size values pulled straight from the reference design. All positions,
  sizes, colors, copy and effects remain merchant-editable via schema —
  the values below are simply the pixel-accurate defaults.

  100% Liquid + HTML + CSS + vanilla JS. No external libraries, no jQuery.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign sec = section.settings
  assign enable_rotation = sec.enable_rotation
  assign enable_shadow = sec.enable_shadow
  assign enable_animation = sec.enable_animation
-%}

<section
  class="editorial-showcase section-{{ section.id }}-padding"
  id="shopify-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-animation="{{ enable_animation }}"
  data-animation-type="{{ sec.animation_type }}"
>
  {%- if sec.background_image != blank -%}
    <div class="editorial-showcase__bg-image" aria-hidden="true">
      {{
        sec.background_image
        | image_url: width: 3200
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '750, 1100, 1500, 2000, 2600, 3200',
          alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="editorial-showcase__container">
    {%- comment -%} Fixed-aspect-ratio collage canvas — every child is positioned by % {%- endcomment -%}
    <div class="editorial-showcase__canvas">

      {%- comment -%} ============ NEW LAUNCH LABEL + SCRIBBLE UNDERLINE ============ {%- endcomment -%}
      {%- if sec.label_text != blank -%}
        <div
          class="editorial-showcase__label-layer"
          {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
        >
          <span class="editorial-showcase__label{% if enable_rotation %} is-rotated{% endif %}{% if sec.use_handwritten_font %} is-handwritten{% endif %}">
            {{ sec.label_text | escape }}
          </span>
          <svg class="editorial-showcase__scribble" viewBox="0 0 240 20" preserveAspectRatio="none" aria-hidden="true">
            <path d="M3,10 C40,18 90,2 130,9 C165,15 200,4 236,11" />
          </svg>
        </div>
      {%- endif -%}

      {%- comment -%} ============ HEADING ============ {%- endcomment -%}
      {%- if sec.heading != blank -%}
        <div
          class="editorial-showcase__heading-layer"
          {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
        >
          <h2 class="editorial-showcase__heading">{{ sec.heading }}</h2>
        </div>
      {%- endif -%}

      {%- comment -%} ============ HIGHLIGHT BADGE ============ {%- endcomment -%}
      {%- if sec.highlight_text != blank -%}
        <div
          class="editorial-showcase__badge-layer"
          {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
        >
          {%- if sec.highlight_tagline != blank -%}
            <span class="editorial-showcase__highlight-tagline">{{ sec.highlight_tagline | escape }}</span>
          {%- endif -%}
          <span class="editorial-showcase__highlight-badge{% if enable_rotation %} is-rotated{% endif %}{% if enable_shadow %} has-shadow{% endif %}">
            {{ sec.highlight_text | escape }}
          </span>
        </div>
      {%- endif -%}

      {%- comment -%} ============ BODY DESCRIPTION ============ {%- endcomment -%}
      {%- if sec.description != blank -%}
        <div
          class="editorial-showcase__body-layer"
          {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
        >
          <div class="editorial-showcase__description">{{ sec.description }}</div>

          {%- if sec.button_text != blank -%}
            <div class="editorial-showcase__cta">
              <a
                {% if sec.button_url != blank %}
                  href="{{ sec.button_url }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                class="editorial-showcase__button editorial-showcase__button--{{ sec.button_style }}"
              >
                {{ sec.button_text | escape }}
              </a>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} ============ POLAROID-STYLE FEATURED PHOTO ============ {%- endcomment -%}
      <div
        class="editorial-showcase__photo-layer"
        {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
      >
        <div class="editorial-showcase__photo-frame{% if enable_rotation %} is-rotated{% endif %}{% if enable_shadow %} has-shadow{% endif %}">
          {%- if sec.featured_image != blank -%}
            {{
              sec.featured_image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 50vw, 90vw',
                widths: '400, 600, 800, 1000, 1200, 1600',
                class: 'editorial-showcase__featured-img',
                alt: sec.featured_image.alt | default: sec.heading | strip_html | escape
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-showcase__featured-img editorial-showcase__placeholder' }}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ============ FABRIC SWATCH CARD (ZIGZAG EDGE) ============ {%- endcomment -%}
      {%- if sec.swatch_image != blank -%}
        <div
          class="editorial-showcase__swatch-layer"
          {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
        >
          <div class="editorial-showcase__swatch-card{% if enable_rotation %} is-rotated{% endif %}{% if enable_shadow %} has-shadow{% endif %}">
            <div class="editorial-showcase__swatch-fold" aria-hidden="true"></div>
            {{
              sec.swatch_image
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 990px) 30vw, 50vw',
                widths: '200, 300, 400, 600, 800',
                class: 'editorial-showcase__swatch-img',
                alt: sec.swatch_image.alt | default: 'Fabric swatch' | escape
            }}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ============ KRAFT STRING TAG ============ {%- endcomment -%}
      {%- if sec.tag_text != blank -%}
        <div
          class="editorial-showcase__tag-layer"
          {% if enable_animation %}data-aos="{{ sec.animation_type }}"{% endif %}
        >
          <div class="editorial-showcase__tag-card{% if enable_rotation %} is-rotated{% endif %}{% if enable_shadow %} has-shadow{% endif %}">
            <span class="editorial-showcase__tag-hole" aria-hidden="true"></span>
            <span class="editorial-showcase__tag-text">{{ sec.tag_text }}</span>
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- comment -%} ============================ INLINE SECTION STYLES ============================ {%- endcomment -%}
<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ sec.padding_top }}px;
    padding-bottom: {{ sec.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase {
    background-color: {{ sec.background_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__container {
    max-width: {{ sec.max_width }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__canvas {
    background-color: {{ sec.content_card_bg }};
    border-radius: {{ sec.card_border_radius }}px;
    aspect-ratio: {{ sec.canvas_aspect_ratio }};
  }

  /* ---- Label / heading / badge / body layer positions (percentage-based) ---- */
  #shopify-section-{{ section.id }} .editorial-showcase__label-layer {
    left: {{ sec.label_pos_x }}%;
    top: {{ sec.label_pos_y }}%;
    width: {{ sec.label_pos_w }}%;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__heading-layer {
    left: {{ sec.heading_pos_x }}%;
    top: {{ sec.heading_pos_y }}%;
    width: {{ sec.heading_pos_w }}%;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__badge-layer {
    left: {{ sec.badge_pos_x }}%;
    top: {{ sec.badge_pos_y }}%;
    width: {{ sec.badge_pos_w }}%;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__body-layer {
    left: {{ sec.body_pos_x }}%;
    top: {{ sec.body_pos_y }}%;
    width: {{ sec.body_pos_w }}%;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__photo-layer {
    left: {{ sec.photo_pos_x }}%;
    top: {{ sec.photo_pos_y }}%;
    width: {{ sec.photo_pos_w }}%;
    height: {{ sec.photo_pos_h }}%;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__swatch-layer {
    left: {{ sec.swatch_pos_x }}%;
    top: {{ sec.swatch_pos_y }}%;
    width: {{ sec.swatch_pos_w }}%;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__tag-layer {
    left: {{ sec.tag_pos_x }}%;
    top: {{ sec.tag_pos_y }}%;
    width: {{ sec.tag_pos_w }}%;
  }

  /* ---- Typography / color ---- */
  #shopify-section-{{ section.id }} .editorial-showcase__label {
    color: {{ sec.label_color }};
    font-size: {{ sec.label_size_mobile }}px;
  }
  #shopify-section-{{ section.id }} .editorial-showcase__scribble path {
    stroke: {{ sec.label_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__heading {
    color: {{ sec.heading_color }};
    font-size: {{ sec.heading_size_mobile }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__description {
    color: {{ sec.description_color }};
    font-size: {{ sec.description_size_mobile }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__highlight-tagline {
    color: {{ sec.tagline_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__highlight-badge {
    background-color: {{ sec.badge_bg_color }};
    color: {{ sec.badge_text_color }};
    border-radius: {{ sec.badge_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__photo-frame {
    background-color: {{ sec.photo_frame_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__featured-img {
    border-radius: {{ sec.image_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__tag-card {
    background-color: {{ sec.tag_bg_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__tag-text {
    color: {{ sec.tag_text_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__button {
    border-radius: {{ sec.button_border_radius }}px;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .editorial-showcase__label {
      font-size: {{ sec.label_size_desktop }}px;
    }
    #shopify-section-{{ section.id }} .editorial-showcase__heading {
      font-size: {{ sec.heading_size_desktop }}px;
    }
    #shopify-section-{{ section.id }} .editorial-showcase__description {
      font-size: {{ sec.description_size_desktop }}px;
    }
  }

  {%- if sec.button_style == 'solid' -%}
    #shopify-section-{{ section.id }} .editorial-showcase__button--solid {
      background-color: {{ sec.button_bg_color }};
      color: {{ sec.button_text_color }};
      border: 2px solid {{ sec.button_bg_color }};
    }
    #shopify-section-{{ section.id }} .editorial-showcase__button--solid:hover {
      background-color: transparent;
      color: {{ sec.button_bg_color }};
    }
  {%- else -%}
    #shopify-section-{{ section.id }} .editorial-showcase__button--outline {
      background-color: transparent;
      color: {{ sec.button_bg_color }};
      border: 2px solid {{ sec.button_bg_color }};
    }
    #shopify-section-{{ section.id }} .editorial-showcase__button--outline:hover {
