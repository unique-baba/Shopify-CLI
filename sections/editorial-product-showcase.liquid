{{ 'editorial-product-showcase.css' | asset_url | stylesheet_tag }}
{%- comment -%}
  ============================================================================
  Editorial Product Showcase Section
  ----------------------------------------------------------------------------
  A premium, magazine / storytelling product showcase built for Dawn (OS 2.0).
  Replicates a layered paper-collage editorial layout:
    - Left content card (label, heading, badge, descriptions, CTA)
    - Right featured image
    - Overlapping fabric swatch card
    - Floating product tag card
  100% Liquid + HTML + CSS + vanilla JS. No external libraries, no jQuery.
  ============================================================================
{%- endcomment -%}

{%- liquid
  assign sec = section.settings

  assign heading_fs_desktop = sec.heading_size_desktop
  assign heading_fs_mobile = sec.heading_size_mobile

  assign enable_rotation = sec.enable_rotation
  assign enable_shadow = sec.enable_shadow
  assign enable_overlap = sec.enable_overlap
  assign enable_animation = sec.enable_animation

  assign image_position = sec.image_position
  assign mobile_order = sec.mobile_layout_order
  assign content_align = sec.content_alignment
-%}

<section
  class="editorial-showcase section-{{ section.id }}-padding"
  id="shopify-section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-animation="{{ enable_animation }}"
  data-animation-type="{{ sec.animation_type }}"
>
  {%- if sec.background_image != blank -%}
    <div class="editorial-showcase__bg-image" aria-hidden="true">
      {{
        sec.background_image
        | image_url: width: 3200
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '750, 1100, 1500, 2000, 2600, 3200',
          alt: ''
      }}
    </div>
  {%- endif -%}

  <div class="editorial-showcase__container editorial-showcase__container--{{ image_position }}">
    <div
      class="editorial-showcase__grid editorial-showcase__grid--{{ image_position }} editorial-showcase__grid--mobile-{{ mobile_order }}"
    >

      {%- comment -%} ============ LEFT / CONTENT SIDE ============ {%- endcomment -%}
      <div class="editorial-showcase__content-col editorial-showcase__content-col--align-{{ content_align }}">
        <div
          class="editorial-showcase__content-card{% if enable_rotation %} is-rotated{% endif %}{% if enable_shadow %} has-shadow{% endif %}"
          {% if enable_animation %}
            data-aos="{{ sec.animation_type }}"
          {% endif %}
        >
          {%- if sec.label_text != blank -%}
            <div class="editorial-showcase__label-wrap">
              <span class="editorial-showcase__label">
                {{ sec.label_text | escape }}
                {%- if sec.label_badge_letter != blank -%}
                  <span class="editorial-showcase__label-badge">{{ sec.label_badge_letter | escape }}</span>
                {%- endif -%}
              </span>
            </div>
          {%- endif -%}

          {%- if sec.heading != blank -%}
            <h2 class="editorial-showcase__heading">{{ sec.heading }}</h2>
          {%- endif -%}

          {%- if sec.highlight_text != blank -%}
            <div class="editorial-showcase__highlight-wrap">
              <span class="editorial-showcase__highlight-tagline">{{ sec.highlight_tagline | escape }}</span>
              <span class="editorial-showcase__highlight-badge{% if enable_rotation %} is-rotated-rev{% endif %}">
                {{ sec.highlight_text | escape }}
              </span>
            </div>
          {%- endif -%}

          {%- if sec.description != blank -%}
            <div class="editorial-showcase__description">{{ sec.description }}</div>
          {%- endif -%}

          {%- if sec.button_text != blank -%}
            <div class="editorial-showcase__cta">
              <a
                {% if sec.button_url != blank %}
                  href="{{ sec.button_url }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                class="editorial-showcase__button editorial-showcase__button--{{ sec.button_style }}"
              >
                {{ sec.button_text | escape }}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ============ RIGHT / IMAGE SIDE ============ {%- endcomment -%}
      <div class="editorial-showcase__image-col">
        <div class="editorial-showcase__image-stage">

          {%- comment -%} Main featured image {%- endcomment -%}
          <div
            class="editorial-showcase__featured-wrap{% if enable_shadow %} has-shadow{% endif %}"
            {% if enable_animation %}
              data-aos="{{ sec.animation_type }}"
            {% endif %}
          >
            {%- if sec.featured_image != blank -%}
              {{
                sec.featured_image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 50vw, 100vw',
                  widths: '400, 600, 800, 1000, 1200, 1600',
                  class: 'editorial-showcase__featured-img',
                  alt: sec.featured_image.alt | default: sec.heading | escape
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-showcase__featured-img editorial-showcase__placeholder' }}
            {%- endif -%}
          </div>

          {%- comment -%} Fabric swatch overlapping card {%- endcomment -%}
          {%- if sec.swatch_image != blank -%}
            <div
              class="editorial-showcase__swatch-wrap{% if enable_rotation %} is-rotated{% endif %}{% if enable_shadow %} has-shadow{% endif %}{% if enable_overlap %} is-overlapping{% endif %}"
              {% if enable_animation %}
                data-aos="{{ sec.animation_type }}"
              {% endif %}
            >
              <div class="editorial-showcase__swatch-inner">
                {{
                  sec.swatch_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 30vw, 60vw',
                    widths: '200, 300, 400, 600, 800',
                    class: 'editorial-showcase__swatch-img',
                    alt: sec.swatch_image.alt | default: 'Fabric swatch' | escape
                }}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Floating product tag card {%- endcomment -%}
          {%- if sec.tag_text != blank -%}
            <div
              class="editorial-showcase__tag-wrap{% if enable_rotation %} is-rotated-rev{% endif %}{% if enable_shadow %} has-shadow{% endif %}{% if enable_overlap %} is-overlapping{% endif %}"
              {% if enable_animation %}
                data-aos="{{ sec.animation_type }}"
              {% endif %}
            >
              <div class="editorial-showcase__tag-hole" aria-hidden="true"></div>
              <span class="editorial-showcase__tag-text">{{ sec.tag_text }}</span>
            </div>
          {%- endif -%}

        </div>
      </div>

    </div>
  </div>
</section>

{%- comment -%} ============================ INLINE SECTION STYLES ============================ {%- endcomment -%}
<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ sec.padding_top }}px;
    padding-bottom: {{ sec.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase {
    background-color: {{ sec.background_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__container {
    max-width: {{ sec.max_width }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__content-card {
    background-color: {{ sec.content_card_bg }};
    border-radius: {{ sec.card_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__heading {
    color: {{ sec.heading_color }};
    font-size: {{ heading_fs_mobile }}px;
  }

  @media (min-width: 750px) {
    #shopify-section-{{ section.id }} .editorial-showcase__heading {
      font-size: {{ heading_fs_desktop }}px;
    }
  }

  #shopify-section-{{ section.id }} .editorial-showcase__description {
    color: {{ sec.description_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__highlight-badge {
    background-color: {{ sec.badge_bg_color }};
    color: {{ sec.badge_text_color }};
    border-radius: {{ sec.badge_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__featured-img {
    border-radius: {{ sec.image_border_radius }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__swatch-wrap {
    width: {{ sec.swatch_size }}px;
  }

  #shopify-section-{{ section.id }} .editorial-showcase__tag-wrap {
    background-color: {{ sec.tag_bg_color }};
    color: {{ sec.tag_text_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__tag-text {
    color: {{ sec.tag_text_color }};
  }

  #shopify-section-{{ section.id }} .editorial-showcase__button {
    border-radius: {{ sec.button_border_radius }}px;
  }

  {%- if sec.button_style == 'solid' -%}
    #shopify-section-{{ section.id }} .editorial-showcase__button--solid {
      background-color: {{ sec.button_bg_color }};
      color: {{ sec.button_text_color }};
      border: 2px solid {{ sec.button_bg_color }};
    }
    #shopify-section-{{ section.id }} .editorial-showcase__button--solid:hover {
      background-color: transparent;
      color: {{ sec.button_bg_color }};
    }
  {%- else -%}
    #shopify-section-{{ section.id }} .editorial-showcase__button--outline {
      background-color: transparent;
      color: {{ sec.button_bg_color }};
      border: 2px solid {{ sec.button_bg_color }};
    }
    #shopify-section-{{ section.id }} .editorial-showcase__button--outline:hover {
      background-color: {{ sec.button_bg_color }};
      color: {{ sec.button_text_color }};
    }
  {%- endif -%}
</style>

<script>
    /**
 * Editorial Product Showcase — assets/editorial-product-showcase.js
 * Lightweight vanilla-JS scroll-in animation using IntersectionObserver.
 * No external libraries, no jQuery, no console errors.
 */
(function () {
  'use strict';
 
  function initEditorialShowcase(root) {
    if (!root || root.dataset.animation !== 'true') return;
 
    var targets = root.querySelectorAll('[data-aos]');
    if (!targets.length) return;
 
    if (!('IntersectionObserver' in window)) {
      // Fallback: reveal immediately if IntersectionObserver isn't supported.
      targets.forEach(function (el) {
        el.classList.add('is-visible');
      });
      return;
    }
 
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
 
    targets.forEach(function (el, index) {
      // Slight stagger for a layered, editorial reveal.
      el.style.transitionDelay = (index * 90) + 'ms';
      observer.observe(el);
    });
  }
 
  function setupAll() {
    var sections = document.querySelectorAll('.editorial-showcase');
    sections.forEach(initEditorialShowcase);
  }
 
  document.addEventListener('DOMContentLoaded', setupAll);
 
  // Re-init when the section is added/edited live in the Theme Editor.
  document.addEventListener('shopify:section:load', function (event) {
    var section = event.target.querySelector('.editorial-showcase');
    if (section) initEditorialShowcase(section);
  });
 
  document.addEventListener('shopify:section:select', function (event) {
    var section = event.target.querySelector('.editorial-showcase');
    if (section) initEditorialShowcase(section);
  });
})();
</script>

